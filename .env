# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=cost_intelligence
POSTGRES_USER=ci_user
POSTGRES_PASSWORD=ci_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Ollama ──────────────────────────────────────────────────────────────────
# Ollama running natively on Windows — reachable from Docker via host.docker.internal
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_CONTEXT_WINDOW=4096

# Model names (must match `ollama list`)
MODEL_DEFAULT=qwen2.5:7b
MODEL_REASONING=deepseek-r1:7b
MODEL_FALLBACK=llama3.2:3b

# ─── Routing thresholds ───────────────────────────────────────────────────────
DEEPSEEK_TRIGGER_SEVERITY=HIGH        # HIGH or CRITICAL triggers deepseek-r1
DEEPSEEK_CONFIDENCE_THRESHOLD=0.80
FALLBACK_TIMEOUT_MS=120000            # 2 minutes for CPU-based 7B model inference
MAX_DEEPSEEK_CALLS_PER_HOUR=10
MAX_OLLAMA_WORKERS=5

# ─── Email (MailHog for demo) ────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=costbot@enterprise.local
ALERT_EMAIL=finance@company.local

# ─── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-32-chars-min
APP_ENV=development
LOG_LEVEL=INFO

# ─── Cost thresholds ─────────────────────────────────────────────────────────
AUTO_APPROVE_LIMIT=50000              # Actions above ₹50,000 require human approval
SLA_ESCALATION_THRESHOLD=0.70        # P(breach) >= 0.70 triggers escalation
DUPLICATE_WINDOW_DAYS=30
UNUSED_LICENSE_DAYS=60
